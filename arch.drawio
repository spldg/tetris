                </mxCell>
                <mxCell id="30" value="Фигура. Группа клеток, объединенных логически.&lt;br&gt;по сути особо ничего не делает самостоятельно." style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=34;position=0.08;position2=0;" vertex="1" parent="1">
                    <mxGeometry x="350" y="730" width="190" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="32" value="Все сущности являются Pixi Container (возможно кроме Shape т.к. он может быть тупо матрицей)&lt;br&gt;&lt;br&gt;Поэтому они буквально добавляются друг в друга, а не в stage. И инициализируют свои поля сами, а не получают в конструктор" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingTop=0;spacingLeft=8;spacingRight=4;" vertex="1" parent="1">
