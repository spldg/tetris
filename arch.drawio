                <mxCell id="26" value="Занимается вписыванием поля в экран. И тикрейтом поля" style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=34;position=0.08;position2=0;" vertex="1" parent="1">
