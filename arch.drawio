                <mxCell id="27" value="Общий контейнер для сетки, шейпов.&lt;br&gt;По сути &quot;изолированный мир тетриса&quot;, который можно просто тикать извне." style="shape=callout;whiteSpace=wrap;html=1;perimeter=calloutPerimeter;size=34;position=0.08;position2=0;" vertex="1" parent="1">
